[global]
    monitor = 0
    follow = keyboard
    width = (250, 500)
    height = (0, 750)
    origin = top-right
    offset = (17, 25)
    notification_limit = 20
    transparency = 20
    padding = 8
    horizontal_padding = 8
    text_icon_padding = 0
    frame_color = "#ffffff"
    frame_width = 0
    gap_size = 3
    font = UbuntuMono Nerd Font 15
    enable_posix_regex = true
    icon_position = left
    min_icon_size = 32
    max_icon_size = 32
    corner_radius = 5
    corners = all
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    timeout = 3

[urgency_normal]
    timeout = 5
    override_pause_level = 30

[urgency_critical]
    timeout = 15
    override_pause_level = 60
    default_icon = dialog-warning

# Custom Icons
[Discord]
    appname = discord
    format = "<b>%s</b>:\n%b"
    new_icon = discord

